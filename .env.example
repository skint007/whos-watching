EMBY_URL=http://localhost:8096
EMBY_API_KEY=your_emby_api_key_here

JELLYFIN_URL=http://localhost:8097
JELLYFIN_API_KEY=your_jellyfin_api_key_here

# SSH host where sonarr/radarr containers run (leave empty to skip)
ENCODE_SSH_HOST=
# Comma-separated container names to check for ffmpeg processes
ENCODE_CONTAINERS=sonarr,radarr
# Use sudo for docker commands (true if your user isn't in the docker group)
ENCODE_USE_SUDO=false