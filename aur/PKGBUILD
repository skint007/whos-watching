# Maintainer: skint007 <archlinux.repose742@passmail.net>
# Built from source by the `paw` personal repo CI (not the official AUR).
pkgname=whos-watching
pkgver=0.0.0
pkgrel=1
pkgdesc="Check active Emby/Jellyfin streams and Sonarr/Radarr encoding jobs from the terminal"
arch=('any')
url="https://github.com/skint007/whos-watching"
license=('MIT')
depends=('python')
makedepends=('git')
optdepends=('openssh: monitor ffmpeg encoding jobs in remote Docker containers over SSH')
conflicts=('whos-watching-bin' 'whos-watching-git')
source=("git+https://github.com/skint007/whos-watching.git")
sha256sums=('SKIP')

pkgver() {
    cd "$srcdir/$pkgname"
    # Base version from __version__ in the script + a monotonic git suffix,
    # e.g. 1.2.0.r5.a1b2c3d. Every commit bumps it so a paw rebuild reads as an update.
    local v r h
    v=$(grep -m1 '^__version__' whos-watching.py | cut -d'"' -f2)
    r=$(git rev-list --count HEAD)
    h=$(git rev-parse --short=7 HEAD)
    printf '%s.r%s.%s' "$v" "$r" "$h"
}

package() {
    cd "$srcdir/$pkgname"
    install -Dm755 whos-watching.py "$pkgdir/usr/bin/whos-watching"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm644 .env.example "$pkgdir/usr/share/doc/$pkgname/env.example"
}
